/* components/package-bar/index.wxss */
.package-bar {
  width: 100%;
}

.bar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.bar-label {
  font-size: 24rpx;
  color: #6B7280;
}

.bar-numbers {
  display: flex;
  align-items: baseline;
}

.remaining-num {
  font-size: 40rpx;
  font-weight: 600;
  color: #4A90D9;
}

.total-num {
  font-size: 26rpx;
  color: #9CA3AF;
  margin-left: 4rpx;
}

.bar-track {
  width: 100%;
  height: 16rpx;
  background: #F0F1F3;
  border-radius: 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90D9, #6BA8E8);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.bar-fill.warning {
  background: linear-gradient(90deg, #FF9F5A, #FFB880);
}

.bar-fill.danger {
  background: linear-gradient(90deg, #F56C6C, #F88E8E);
}

.bar-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.consumed-text {
  font-size: 22rpx;
  color: #9CA3AF;
}

.remaining-text {
  font-size: 22rpx;
  color: #6B7280;
}
