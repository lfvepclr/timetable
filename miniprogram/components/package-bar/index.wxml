<!-- components/package-bar/index.wxml -->
<view class="package-bar">
  <view class="bar-header" wx:if="{{showLabel}}">
    <text class="bar-label">课时进度</text>
    <view class="bar-numbers">
      <text class="remaining-num">{{remaining}}</text>
      <text class="total-num">/{{total}}</text>
    </view>
  </view>
  <view class="bar-track">
    <view class="bar-fill {{percent >= 80 ? 'warning' : ''}} {{percent >= 100 ? 'danger' : ''}}" style="width: {{percent}}%;"></view>
  </view>
  <view class="bar-footer" wx:if="{{showLabel}}">
    <text class="consumed-text">已上 {{consumed}} 节</text>
    <text class="remaining-text">剩余 {{remaining}} 节</text>
  </view>
</view>
