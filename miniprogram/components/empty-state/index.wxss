/* components/empty-state/index.wxss */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  margin-bottom: 24rpx;
}

.icon-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #F0F4F8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-inner {
  width: 48rpx;
  height: 48rpx;
  border-radius: 8rpx;
  border: 4rpx solid #C5CCD6;
  background: transparent;
  position: relative;
}

.icon-inner::after {
  content: '';
  position: absolute;
  bottom: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 72rpx;
  height: 4rpx;
  background: #C5CCD6;
  border-radius: 2rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

.empty-action {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  background: #4A90D9;
  color: #FFFFFF;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.action-hover {
  opacity: 0.85;
}
