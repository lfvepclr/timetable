<!-- components/lesson-card/index.wxml -->
<wxs src="/wxs/helpers.wxs" module="h" />
<view class="lesson-card {{compact ? 'compact' : ''}}" bindtap="onTap" hover-class="card-hover">
  <!-- 左侧课程色条 -->
  <view class="course-bar" style="background: {{lesson.color || '#5B7CF9'}};"></view>

  <view class="card-body">
    <!-- 顶部：时间 + 课程名 -->
    <view class="card-header">
      <view class="time-block">
        <text class="start-time">{{lesson.start_time}}</text>
        <text class="time-sep">-</text>
        <text class="end-time">{{lesson.end_time}}</text>
      </view>
      <view class="course-info">
        <text class="course-name text-ellipsis">{{lesson.course_name}}</text>
        <text class="course-type">{{lesson.course_type}}</text>
      </view>
      <t-tag theme="{{h.statusTheme(lesson.lesson_status, 'lesson')}}" variant="light" size="small">{{h.statusText(lesson.lesson_status, 'lesson')}}</t-tag>
    </view>

    <!-- 底部：学生列表 -->
    <view class="card-footer" wx:if="{{!compact}}">
      <view class="students-row">
        <block wx:for="{{lesson.students}}" wx:key="student_id">
          <t-tag size="small" variant="light" theme="{{item.status === 'on_leave' ? 'warning' : 'default'}}">
            {{item.student_name}}
          </t-tag>
        </block>
      </view>
      <view class="date-label" wx:if="{{showDate}}">
        <text>{{lesson.date}}</text>
      </view>
    </view>

    <!-- 紧凑模式：学生名一行 -->
    <view class="compact-students" wx:if="{{compact}}">
      <text class="text-ellipsis">{{lesson.students[0].student_name}}</text>
      <t-badge wx:if="{{lesson.students.length > 1}}" count="+{{lesson.students.length - 1}}" shape="circle" />
    </view>
  </view>
</view>
