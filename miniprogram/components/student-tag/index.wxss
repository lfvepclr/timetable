/* components/student-tag/index.wxss */
.student-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  background: #F0F4F8;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #4B5563;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.tag-hover {
  opacity: 0.7;
}

.student-tag.selected {
  background: #EAF2FB;
  color: #4A90D9;
  border-color: #4A90D9;
}

.student-tag.on-leave {
  background: #FFF3E8;
  color: #FF9F5A;
  text-decoration: line-through;
}

.leave-mark {
  font-size: 18rpx;
  margin-left: 6rpx;
  background: #FF9F5A;
  color: #FFFFFF;
  padding: 0 8rpx;
  border-radius: 6rpx;
  text-decoration: none;
}
