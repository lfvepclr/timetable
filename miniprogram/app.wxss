/* app.wxss - 全局样式 */

/* TDesign 主题变量覆盖 */
page {
  --td-brand-color: #5B7CF9;
  --td-brand-color-light: #EEF2FF;
  --td-brand-color-focus: #DBE4FE;
  --td-brand-color-disabled: #B4C4FC;
  --td-brand-color-hover: #4C6AEF;
  --td-brand-color-active: #3D5AE0;
  --td-success-color: #10B981;
  --td-warning-color: #F59E0B;
  --td-error-color: #EF4444;
  --td-bg-color-page: #F8F9FB;
  --td-bg-color-container: #FFFFFF;
  --td-text-color-primary: #111827;
  --td-text-color-secondary: #6B7280;
  --td-text-color-placeholder: #9CA3AF;
  --td-border-color: #E5E7EB;
  --td-radius-default: 16rpx;
  --td-radius-large: 24rpx;
}

/* 引入公共变量和混入 */
@import "styles/variables.wxss";
@import "styles/mixins.wxss";

page {
  background-color: #F7F8FA;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: #1F2937;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

view, text, input, textarea, button, image, scroll-view {
  box-sizing: border-box;
}

/* 去除按钮默认样式 */
button {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: normal;
}

button::after {
  border: none;
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 通用卡片 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* 文本截断 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 通用圆形头像（用于 t-cell left-icon slot） */
.cell-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.cell-avatar-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}
