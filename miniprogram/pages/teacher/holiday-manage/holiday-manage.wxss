/* pages/teacher/holiday-manage/holiday-manage.wxss */
@import '/styles/variables.wxss';

.page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

.year-bar {
  padding: 24rpx 32rpx;
  background: var(--color-card);
}

.year-picker {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-primary);
}

.section {
  margin: 24rpx;
  padding: 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text-primary);
}

.add-btn {
  font-size: var(--font-sm);
  color: var(--color-primary);
  padding: 8rpx 24rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: var(--radius-pill);
}

.holiday-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.holiday-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
}

.holiday-date {
  width: 180rpx;
  font-size: var(--font-sm);
  color: var(--color-text-primary);
  font-weight: 500;
}

.holiday-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.holiday-name {
  font-size: var(--font-base);
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.holiday-type {
  font-size: var(--font-xs);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-sm);
  display: inline-block;
  width: fit-content;
}

.type-off {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.type-work {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.holiday-source {
  font-size: var(--font-xs);
  color: var(--color-text-placeholder);
  margin: 0 16rpx;
}

.delete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--color-danger);
}

.vacation-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.vacation-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
}

.vacation-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-warning-bg);
  color: var(--color-warning);
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.vacation-info {
  display: flex;
  flex-direction: column;
}

.vacation-name {
  font-size: var(--font-base);
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.vacation-range {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.dialog {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 0;
  background: var(--color-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  z-index: 101;
}

.dialog-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: 32rpx;
}

.dialog-body {
  margin-bottom: 32rpx;
}

.dialog-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.dialog-label {
  font-size: var(--font-base);
  color: var(--color-text-regular);
}

.dialog-picker {
  font-size: var(--font-base);
  color: var(--color-primary);
}

.dialog-input {
  text-align: right;
  font-size: var(--font-base);
  color: var(--color-text-primary);
}

.type-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-left: 16rpx;
}

.dialog-actions {
  display: flex;
  gap: 24rpx;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  border: none;
}

.btn-cancel {
  background: var(--color-info-bg);
  color: var(--color-text-secondary);
}

.btn-confirm {
  background: var(--color-primary);
  color: #fff;
}
