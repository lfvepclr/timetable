/* pages/teacher/feedback-card/feedback-card.wxss */
@import '/styles/variables.wxss';

.page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: env(safe-area-inset-bottom);
  padding-bottom: constant(safe-area-inset-bottom);
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-base);
}

.canvas-wrapper {
  position: relative;
  display: flex;
  justify-content: center;
  padding: 24rpx;
}

.feedback-canvas {
  width: 375px;
  height: 720px;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.canvas-placeholder {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: var(--color-text-secondary);
  font-size: var(--font-base);
}

.actions {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 120rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-sm);
  border: none;
  padding: 0;
}

.action-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.btn-save {
  background: var(--color-primary);
  color: #fff;
}

.btn-share {
  background: var(--color-success);
  color: #fff;
}

.btn-notify {
  background: var(--color-warning);
  color: #fff;
}

.action-btn[disabled] {
  opacity: 0.6;
}
