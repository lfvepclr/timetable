<!-- pages/teacher/feedback-card/feedback-card.wxml -->
<view class="page">
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading}}">
    <!-- Canvas 卡片预览 -->
    <view class="canvas-wrapper">
      <canvas
        type="2d"
        id="feedbackCanvas"
        class="feedback-canvas"
        style="width: 375px; height: 720px;"
      ></canvas>
      <view class="canvas-placeholder" wx:if="{{!cardReady}}">
        <text>正在生成精美卡片...</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions" wx:if="{{cardReady}}">
      <button class="action-btn btn-save" bindtap="saveToAlbum" loading="{{saving}}" disabled="{{saving}}">
        <text class="btn-icon">↓</text>
        <text>保存相册</text>
      </button>
      <button class="action-btn btn-share" open-type="share">
        <text class="btn-icon">↗</text>
        <text>分享家长</text>
      </button>
      <button class="action-btn btn-notify" bindtap="notifyParent" loading="{{notifying}}" disabled="{{notifying}}">
        <text class="btn-icon">🔔</text>
        <text>通知家长</text>
      </button>
    </view>
  </block>
</view>
