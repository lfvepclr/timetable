<!-- pages/teacher/feedback-card/feedback-card.wxml -->
<view class="page">
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading}}">
    <!-- Canvas 卡片预览 -->
    <view class="canvas-wrapper">
      <canvas
        type="2d"
        id="feedbackCanvas"
        class="feedback-canvas"
        style="width: 375px; height: 720px;"
      ></canvas>
      <view class="canvas-placeholder" wx:if="{{!cardReady}}">
        <text>正在生成精美卡片...</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions" wx:if="{{cardReady}}">
      <t-button class="action-btn" theme="default" bind:tap="saveToAlbum" loading="{{saving}}" disabled="{{saving}}">
        <text class="btn-icon">↓</text>
        <text>保存相册</text>
      </t-button>
      <t-button class="action-btn" theme="primary" open-type="share">
        <text class="btn-icon">↗</text>
        <text>分享家长</text>
      </t-button>
      <t-button class="action-btn" theme="warning" bind:tap="notifyParent" loading="{{notifying}}" disabled="{{notifying}}">
        <text class="btn-icon">🔔</text>
        <text>通知家长</text>
      </t-button>
    </view>
  </block>
</view>
