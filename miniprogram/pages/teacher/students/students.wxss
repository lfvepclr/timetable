/* pages/teacher/students/students.wxss */
.page-container {
  padding: 16rpx 24rpx 120rpx;
}

.search-bar {
  margin-bottom: 24rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 999rpx;
  padding: 16rpx 28rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.student-list {
  min-height: 400rpx;
}

.student-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-hover {
  opacity: 0.85;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.avatar text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.student-info {
  flex: 1;
  min-width: 0;
}

.info-top {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.student-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1F2937;
  margin-right: 16rpx;
}

.student-grade {
  font-size: 22rpx;
  color: #6B7280;
  background: #F0F4F8;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.student-school {
  font-size: 24rpx;
  color: #6B7280;
  display: block;
}

.student-notes {
  font-size: 22rpx;
  color: #9CA3AF;
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow {
  font-size: 36rpx;
  color: #D1D5DB;
  margin-left: 16rpx;
}

.loading-text {
  text-align: center;
  color: #9CA3AF;
  padding: 40rpx;
  font-size: 26rpx;
}

/* 浮动添加按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  background: #5B7CF9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(91, 124, 249, 0.4);
  z-index: 100;
}

.fab-hover {
  opacity: 0.85;
  transform: scale(0.95);
}

.fab-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  line-height: 1;
}

/* 添加弹窗 */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.add-dialog {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.dialog-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1F2937;
  text-align: center;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
  display: block;
}

.form-input {
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  min-height: 100rpx;
  box-sizing: border-box;
}

.dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.dialog-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.dialog-btn.cancel {
  background: #F0F4F8;
  color: #6B7280;
}

.dialog-btn.confirm {
  background: #5B7CF9;
  color: #FFFFFF;
  font-weight: 500;
}
