<!-- pages/teacher/students/students.wxml -->
<wxs src="/wxs/helpers.wxs" module="h" />
<view class="page-container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <t-search value="{{keyword}}" placeholder="搜索学生姓名/年级" bind:change="onSearch" bind:submit="onSearchConfirm" />
  </view>

  <!-- 学生列表 -->
  <view class="student-list" wx:if="{{!loading}}">
    <block wx:for="{{students}}" wx:key="_id">
      <t-cell title="{{item.name}}" note="{{item.grade || ''}} {{item.school || ''}}" description="{{item.pkgSummary}}" arrow hover data-id="{{item._id}}" bind:tap="goToDetail">
        <view slot="left-icon" class="cell-avatar" style="background: {{h.avatarColor(index)}};">
          <text class="cell-avatar-text">{{h.firstChar(item.name)}}</text>
        </view>
      </t-cell>
    </block>
    <t-empty wx:if="{{students.length === 0}}" icon="info-circle-filled" description="暂无学生">
      <t-button theme="primary" size="small" bind:tap="showAddDialog" slot="footer">添加学生</t-button>
    </t-empty>
  </view>
  <view wx:else class="loading-text">加载中...</view>

  <!-- 添加按钮 -->
  <t-fab icon="add" bind:click="showAddDialog" style="bottom: 160rpx" />

  <!-- 添加学生弹窗 -->
  <t-popup visible="{{showAdd}}" bind:visible-change="onPopupVisibleChange" placement="center">
    <view class="add-dialog">
      <view class="dialog-title">添加学生</view>
      <t-input label="姓名" placeholder="请输入学生姓名" value="{{newStudent.name}}" data-field="name" bind:change="onInputChange" />
      <t-input label="年级" placeholder="如：六年级" value="{{newStudent.grade}}" data-field="grade" bind:change="onInputChange" />
      <t-input label="学校" placeholder="选填" value="{{newStudent.school}}" data-field="school" bind:change="onInputChange" />
      <t-textarea label="备注" placeholder="选填，如学习情况" value="{{newStudent.notes}}" data-field="notes" bind:change="onInputChange" />
      <view class="dialog-actions">
        <t-button theme="default" bind:tap="hideAddDialog">取消</t-button>
        <t-button theme="primary" bind:tap="saveStudent">保存</t-button>
      </view>
    </view>
  </t-popup>

  <custom-tab-bar id="tabBar" />
</view>
