/* pages/teacher/lesson-schedule/lesson-schedule.wxss */
@import '/styles/variables.wxss';

.page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 140rpx;
}

.form-section {
  margin: 24rpx;
  padding: 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
}

.add-link {
  font-size: var(--font-sm);
  color: var(--color-primary);
}

.empty-courses {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 40rpx 0;
}

.empty-text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.course-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.course-chip {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-pill);
  background: var(--color-card);
}

.course-chip.selected {
  background: var(--color-primary-bg);
  border-color: var(--color-primary);
}

.chip-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.chip-name {
  font-size: var(--font-sm);
  color: var(--color-text-primary);
  margin-right: 8rpx;
}

.chip-type {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  background: var(--color-info-bg);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-sm);
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  font-size: var(--font-base);
  color: var(--color-text-regular);
}

.picker-value {
  font-size: var(--font-base);
  color: var(--color-primary);
  font-weight: 500;
}

.student-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.student-item {
  position: relative;
  width: 140rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-card);
}

.student-item.selected {
  border-color: var(--color-primary);
  background: var(--color-primary-bg);
}

.student-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.student-item.selected .student-avatar {
  background: var(--color-primary);
  color: #fff;
}

.student-name {
  font-size: var(--font-xs);
  color: var(--color-text-primary);
  text-align: center;
}

.check-mark {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  background: var(--color-card);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.btn-schedule {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-md);
  font-weight: 600;
  border-radius: var(--radius-md);
  border: none;
}

.btn-schedule[disabled] {
  opacity: 0.6;
}
