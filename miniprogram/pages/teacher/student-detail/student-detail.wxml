<!-- pages/teacher/student-detail/student-detail.wxml -->
<wxs src="/wxs/helpers.wxs" module="h" />
<view class="page">
  <block wx:if="{{!loading && student}}">
    <!-- 学生信息卡片 -->
    <view class="info-card">
      <view class="info-header">
        <view class="student-avatar">
          <text>{{h.firstChar(student.name)}}</text>
        </view>
        <view class="info-main">
          <text class="student-name">{{student.name}}</text>
          <view class="info-tags">
            <t-tag wx:if="{{student.grade}}" size="small">{{student.grade}}</t-tag>
            <t-tag wx:if="{{student.school}}" size="small">{{student.school}}</t-tag>
            <t-tag theme="{{student.active ? 'success' : 'default'}}" variant="light" size="small">{{student.active ? '在读' : '已停'}}</t-tag>
          </view>
        </view>
        <t-button wx:if="{{!editMode}}" theme="primary" variant="text" size="small" bind:tap="startEdit">编辑</t-button>
      </view>

      <view class="info-notes" wx:if="{{student.notes && !editMode}}">
        <text class="notes-label">备注：</text>
        <text class="notes-text">{{student.notes}}</text>
      </view>

      <!-- 编辑模式 -->
      <block wx:if="{{editMode}}">
        <view class="edit-form">
          <t-input label="姓名" placeholder="学生姓名" value="{{editData.name}}" data-field="name" bind:change="onEditInput" />
          <t-input label="年级" placeholder="如：三年级" value="{{editData.grade}}" data-field="grade" bind:change="onEditInput" />
          <t-input label="学校" placeholder="学校名称" value="{{editData.school}}" data-field="school" bind:change="onEditInput" />
          <t-textarea label="备注" placeholder="其他信息" value="{{editData.notes}}" data-field="notes" bind:change="onEditInput" />
          <view class="edit-actions">
            <t-button theme="default" bind:tap="cancelEdit">取消</t-button>
            <t-button theme="primary" bind:tap="saveEdit">保存</t-button>
          </view>
        </view>
      </block>
    </view>

    <!-- 快捷操作 -->
    <t-cell-group wx:if="{{!editMode}}">
      <t-cell title="课程包" note="管理课时与消耗" arrow hover bind:tap="goToPackageManage">
        <t-icon slot="left-icon" name="folder" size="40rpx" />
      </t-cell>
      <t-cell title="绑定家长" note="生成绑定码" arrow hover bind:tap="goToBindGenerate">
        <t-icon slot="left-icon" name="link" size="40rpx" />
      </t-cell>
    </t-cell-group>

    <!-- Tab 切换 -->
    <view class="tab-bar" wx:if="{{!editMode}}">
      <view class="tab-item {{activeTab === 'info' ? 'active' : ''}}" data-tab="info" bindtap="switchTab">课程包</view>
      <view class="tab-item {{activeTab === 'lessons' ? 'active' : ''}}" data-tab="lessons" bindtap="switchTab">课程</view>
      <view class="tab-item {{activeTab === 'feedbacks' ? 'active' : ''}}" data-tab="feedbacks" bindtap="switchTab">反馈</view>
    </view>

    <!-- 课程包列表 -->
    <view class="tab-content" wx:if="{{activeTab === 'info' && !editMode}}">
      <view wx:if="{{packages.length === 0}}">
        <t-empty icon="info-circle-filled" description="暂无课程包" />
      </view>
      <view class="pkg-list" wx:else>
        <view class="pkg-card" wx:for="{{packages}}" wx:key="_id">
          <view class="pkg-header">
            <text class="pkg-course">{{item.course_name || '课程'}}</text>
            <t-tag theme="{{h.statusTheme(item.status, 'package')}}" variant="light" size="small">{{h.statusText(item.status, 'package')}}</t-tag>
          </view>
          <t-progress percentage="{{h.packagePercent(item.consumed_lessons, item.total_lessons)}}" label="{{h.packageLabel(item.consumed_lessons, item.total_lessons)}}" />
          <view class="pkg-footer">
            <text class="pkg-date">购买日期：{{item.purchase_date}}</text>
            <text class="pkg-remaining">剩余 {{item.remaining}}/{{item.total_lessons}} 节</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 课程列表 -->
    <view class="tab-content" wx:if="{{activeTab === 'lessons' && !editMode}}">
      <view wx:if="{{recentLessons.length === 0}}">
        <t-empty icon="info-circle-filled" description="暂无课程记录" />
      </view>
      <view class="lesson-list" wx:else>
        <view class="lesson-item" wx:for="{{recentLessons}}" wx:key="_id" data-id="{{item._id}}" bindtap="goToLessonDetail" hover-class="item-hover">
          <view class="lesson-date">
            <text class="date-day">{{item.date}}</text>
            <text class="date-weekday">{{item.day_of_week ? '周' + h.weekdayShort(item.day_of_week) : ''}}</text>
          </view>
          <view class="lesson-info">
            <text class="lesson-name">{{item.course_name || '课程'}}</text>
            <text class="lesson-time">{{item.start_time}} - {{item.end_time}}</text>
          </view>
          <t-tag theme="{{h.statusTheme(item.lesson_status, 'lesson')}}" variant="light" size="small">{{h.statusText(item.lesson_status, 'lesson')}}</t-tag>
        </view>
      </view>
    </view>

    <!-- 反馈列表 -->
    <view class="tab-content" wx:if="{{activeTab === 'feedbacks' && !editMode}}">
      <view wx:if="{{feedbacks.length === 0}}">
        <t-empty icon="info-circle-filled" description="暂无反馈记录" />
      </view>
      <view class="feedback-list" wx:else>
        <view class="feedback-item" wx:for="{{feedbacks}}" wx:key="_id" data-id="{{item._id}}" bindtap="goToFeedbackDetail" hover-class="item-hover">
          <view class="fb-header">
            <text class="fb-date">{{item.lesson_date}}</text>
            <text class="fb-course">{{item.course_name || ''}}</text>
          </view>
          <text class="fb-content">{{item.content}}</text>
        </view>
      </view>
    </view>
  </block>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
