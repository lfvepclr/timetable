/* pages/teacher/course-edit/course-edit.wxss */
.page-container { padding: 24rpx; padding-bottom: 160rpx; min-height: 100vh; background: #F8F9FB; }
.form-card { background: #FFFFFF; border-radius: 16rpx; padding: 32rpx 24rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.form-item { margin-bottom: 28rpx; }
.form-item:last-child { margin-bottom: 0; }
.form-label { font-size: 26rpx; color: #6B7280; margin-bottom: 12rpx; display: block; }
.form-input { background: #F7F8FA; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: #1F2937; }
.picker-value { background: #F7F8FA; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: #1F2937; }
.color-row { display: flex; flex-wrap: wrap; gap: 20rpx; }
.color-dot { width: 56rpx; height: 56rpx; border-radius: 50%; border: 4rpx solid transparent; }
.color-dot.selected { border-color: #1F2937; box-shadow: 0 0 0 4rpx #FFFFFF inset; }
.save-btn { position: fixed; left: 24rpx; right: 24rpx; bottom: calc(24rpx + env(safe-area-inset-bottom)); background: #5B7CF9; color: #FFFFFF; text-align: center; padding: 28rpx 0; border-radius: 999rpx; font-size: 32rpx; font-weight: 500; box-shadow: 0 8rpx 24rpx rgba(91,124,249,0.4); }
.btn-hover { opacity: 0.85; }
