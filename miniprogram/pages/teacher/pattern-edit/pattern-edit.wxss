/* pages/teacher/pattern-edit/pattern-edit.wxss */
.page-container { padding: 24rpx; padding-bottom: 160rpx; }
.form-card { background: #FFFFFF; border-radius: 16rpx; padding: 32rpx 24rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.form-item { margin-bottom: 28rpx; }
.form-item:last-child { margin-bottom: 0; }
.form-row { display: flex; gap: 24rpx; }
.form-item.half { flex: 1; }
.form-label { font-size: 26rpx; color: #6B7280; margin-bottom: 12rpx; display: block; }
.label-row { display: flex; align-items: center; justify-content: space-between; }
.add-link { font-size: 26rpx; color: #5B7CF9; }
.picker-value { background: #F7F8FA; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: #1F2937; }
.picker-value.placeholder { color: #9CA3AF; }
.picker-value.disabled { color: #6B7280; }
.color-row { display: flex; flex-wrap: wrap; gap: 20rpx; }
.color-dot { width: 56rpx; height: 56rpx; border-radius: 50%; border: 4rpx solid transparent; }
.color-dot.selected { border-color: #1F2937; box-shadow: 0 0 0 4rpx #FFFFFF inset; }
.selected-students { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.empty-hint { font-size: 26rpx; color: #9CA3AF; margin-top: 12rpx; }
.save-btn { position: fixed; left: 24rpx; right: 24rpx; bottom: calc(24rpx + env(safe-area-inset-bottom)); background: #5B7CF9; color: #FFFFFF; text-align: center; padding: 28rpx 0; border-radius: 999rpx; font-size: 32rpx; font-weight: 500; box-shadow: 0 8rpx 24rpx rgba(91,124,249,0.4); }
.btn-hover { opacity: 0.85; }
.cycle-type-row { display: flex; gap: 16rpx; }
.cycle-chip { flex: 1; text-align: center; padding: 20rpx 0; background: #F7F8FA; border-radius: 12rpx; font-size: 28rpx; color: #6B7280; border: 2rpx solid transparent; }
.cycle-chip.active { background: #EAF2FB; color: #5B7CF9; border-color: #5B7CF9; font-weight: 500; }
.estimated-count { margin-top: 16rpx; padding: 16rpx 24rpx; background: #F0F4F8; border-radius: 12rpx; font-size: 26rpx; color: #5B7CF9; }
.dialog-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: flex-end; z-index: 1000; }
.picker-dialog { width: 100%; background: #FFFFFF; border-radius: 32rpx 32rpx 0 0; padding: 40rpx 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); max-height: 80vh; }
.dialog-title { font-size: 34rpx; font-weight: 600; color: #1F2937; text-align: center; margin-bottom: 24rpx; }
.student-scroll { max-height: 600rpx; }
.pick-row { display: flex; align-items: center; padding: 20rpx; background: #F7F8FA; border-radius: 12rpx; margin-bottom: 12rpx; }
.pick-row.checked { background: #EAF2FB; }
.pick-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-right: 20rpx; }
.pick-avatar text { font-size: 28rpx; font-weight: 600; color: #FFFFFF; }
.pick-name { flex: 1; font-size: 30rpx; color: #1F2937; }
.pick-check { width: 40rpx; height: 40rpx; border: 4rpx solid #D1D5DB; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #FFFFFF; font-size: 24rpx; }
.pick-check.checked { background: #5B7CF9; border-color: #5B7CF9; }
.dialog-actions { margin-top: 24rpx; }
.dialog-btn { text-align: center; padding: 24rpx 0; border-radius: 999rpx; font-size: 30rpx; }
.dialog-btn.confirm { background: #5B7CF9; color: #FFFFFF; font-weight: 500; }
