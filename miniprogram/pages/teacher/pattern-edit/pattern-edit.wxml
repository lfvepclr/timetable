<!-- pages/teacher/pattern-edit/pattern-edit.wxml -->
<wxs src="/wxs/helpers.wxs" module="h" />
<view class="page-container">
  <view class="form-card">
    <view class="form-item">
      <text class="form-label">课程</text>
      <picker mode="selector" range="{{courses}}" range-key="name" bindchange="onCourseChange">
        <view class="picker-value {{form.course_name ? '' : 'placeholder'}}">{{form.course_name || '请选择课程'}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">周几</text>
      <picker mode="selector" range="{{weekdays}}" range-key="label" bindchange="onDayChange">
        <view class="picker-value">{{weekdays[form.day_of_week - 1].label}}</view>
      </picker>
    </view>

    <view class="form-row">
      <view class="form-item half">
        <text class="form-label">开始时间</text>
        <picker mode="time" value="{{form.start_time}}" bindchange="onStartTimeChange">
          <view class="picker-value">{{form.start_time}}</view>
        </picker>
      </view>
      <view class="form-item half">
        <text class="form-label">时长</text>
        <picker mode="selector" range="{{durations}}" range-key="label" bindchange="onDurationChange">
          <view class="picker-value">{{form.duration}}分钟</view>
        </picker>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">结束时间</text>
      <view class="picker-value disabled">{{form.end_time}}</view>
    </view>

    <view class="form-item">
      <text class="form-label">课程颜色</text>
      <view class="color-row">
        <block wx:for="{{colors}}" wx:key="*this">
          <view class="color-dot {{form.color === item ? 'selected' : ''}}" style="background: {{item}};" data-color="{{item}}" bindtap="onColorChange"></view>
        </block>
      </view>
    </view>

    <view class="form-row">
      <view class="form-item half">
        <text class="form-label">生效起始</text>
        <picker mode="date" value="{{form.valid_from}}" bindchange="onDateChange" data-field="valid_from">
          <view class="picker-value {{form.valid_from ? '' : 'placeholder'}}">{{form.valid_from || '选择日期'}}</view>
        </picker>
      </view>
      <view class="form-item half">
        <text class="form-label">生效截止</text>
        <picker mode="date" value="{{form.valid_until}}" bindchange="onDateChange" data-field="valid_until">
          <view class="picker-value {{form.valid_until ? '' : 'placeholder'}}">{{form.valid_until || '选填'}}</view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 学生选择 -->
  <view class="form-card">
    <view class="form-item">
      <view class="label-row">
        <text class="form-label">参课学生</text>
        <text class="add-link" bindtap="showStudentPicker">+ 选择</text>
      </view>
      <view class="selected-students" wx:if="{{form.student_names.length > 0}}">
        <block wx:for="{{form.student_names}}" wx:key="*this">
          <student-tag name="{{item}}" />
        </block>
      </view>
      <view class="empty-hint" wx:else>暂未选择学生</view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-btn" bindtap="save" hover-class="btn-hover">
    <text>{{isEdit ? '更新' : '创建'}}模板</text>
  </view>
</view>

<!-- 学生选择弹窗 -->
<view wx:if="{{showStudentPicker}}" class="dialog-mask" bindtap="hideStudentPicker">
  <view class="picker-dialog" catchtap="">
    <view class="dialog-title">选择学生</view>
    <scroll-view scroll-y class="student-scroll">
      <block wx:for="{{students}}" wx:key="_id">
        <view class="pick-row {{selectedStudents[item._id] ? 'checked' : ''}}" data-sid="{{item._id}}" data-sname="{{item.name}}" bindtap="toggleStudent">
          <view class="pick-avatar" style="background: {{h.avatarColor(index)}};">
            <text>{{h.firstChar(item.name)}}</text>
          </view>
          <text class="pick-name">{{item.name}}</text>
          <view class="pick-check {{selectedStudents[item._id] ? 'checked' : ''}}">
            <text wx:if="{{selectedStudents[item._id]}}">✓</text>
          </view>
        </view>
      </block>
    </scroll-view>
    <view class="dialog-actions">
      <view class="dialog-btn confirm" bindtap="confirmStudents">确认（{{form.student_ids.length}}）</view>
    </view>
  </view>
</view>
