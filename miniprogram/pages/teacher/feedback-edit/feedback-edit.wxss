/* pages/teacher/feedback-edit/feedback-edit.wxss */
@import '/styles/variables.wxss';

.page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 140rpx;
}

.lesson-info {
  display: flex;
  align-items: center;
  margin: 24rpx;
  padding: 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.lesson-bar {
  width: 6rpx;
  height: 64rpx;
  border-radius: 3rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.lesson-detail {
  display: flex;
  flex-direction: column;
}

.lesson-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.lesson-time {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.form-section {
  margin: 24rpx;
  padding: 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.form-title {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.title-text {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
}

.title-required {
  color: var(--color-danger);
  margin-left: 8rpx;
}

.title-hint {
  font-size: var(--font-xs);
  color: var(--color-text-placeholder);
  margin-left: 16rpx;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  color: var(--color-text-primary);
  line-height: 1.6;
  box-sizing: border-box;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  background: var(--color-card);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.btn-save {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-md);
  font-weight: 600;
  border-radius: var(--radius-md);
  border: none;
}

.btn-save[disabled] {
  opacity: 0.6;
}
