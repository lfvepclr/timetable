/* pages/teacher/index/index.wxss */
.page-container {
  padding: 0 24rpx 120rpx;
}

/* 头部 */
.today-header {
  position: relative;
  margin-bottom: 32rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(135deg, #4A90D9, #6BA8E8);
  border-radius: 20rpx;
}

.header-content {
  position: relative;
  padding: 40rpx 32rpx 32rpx;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.date-block {
  display: flex;
  flex-direction: column;
}

.date-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.weekday-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.today-count {
  display: flex;
  align-items: baseline;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
}

.count-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.count-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 4rpx;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
}

.action-hover {
  opacity: 0.7;
}

.action-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-schedule { background: #EAF2FB; }
.icon-pattern { background: #E8F7F1; }
.icon-calendar { background: #FFF3E8; }

.action-item text {
  font-size: 22rpx;
  color: #4B5563;
}

/* 区块 */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
}

.more-link {
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 400;
}

.loading-text {
  text-align: center;
  color: #9CA3AF;
  padding: 40rpx;
  font-size: 26rpx;
}

/* 近期课程 */
.upcoming-day {
  margin-bottom: 24rpx;
}

.upcoming-date {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.date-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #4A90D9;
  margin-right: 12rpx;
}

.date-full {
  font-size: 22rpx;
  color: #9CA3AF;
}
