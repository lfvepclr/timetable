/* pages/teacher/index/index.wxss */
.page {
  padding: 0 24rpx 160rpx;
  background: #F8F9FB;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 日期概览条 */
.overview-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-top: 16rpx;
  margin-bottom: 20rpx;
}

.date-info {
  display: flex;
  align-items: baseline;
}

.date-main {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.date-week {
  font-size: 26rpx;
  color: #6B7280;
  margin-left: 12rpx;
}

.lesson-count {
  display: flex;
  align-items: baseline;
}

.count-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #5B7CF9;
}

.count-unit {
  font-size: 24rpx;
  color: #6B7280;
  margin-left: 4rpx;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.action-hover {
  opacity: 0.6;
}

.action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.icon-blue {
  background: #EEF2FF;
}

.icon-green {
  background: #ECFDF5;
}

.icon-amber {
  background: #FEF3C7;
}

.action-text {
  font-size: 24rpx;
  color: #374151;
  font-weight: 500;
}

/* 区块 */
.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.more-link {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #6B7280;
}

/* 骨架屏 */
.skeleton-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.skeleton-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.skeleton-row:last-child {
  margin-bottom: 0;
}

.skeleton-bar {
  height: 28rpx;
  border-radius: 8rpx;
  background: #F0F0F2;
  margin-right: 16rpx;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

.w-30 { width: 30%; }
.w-40 { width: 40%; }
.w-50 { width: 50%; }
.w-20 { width: 20%; }

@keyframes skeleton-pulse {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

/* 近期课程日期行 */
.upcoming-date-row {
  display: flex;
  align-items: baseline;
  margin: 24rpx 0 12rpx;
  padding: 0 8rpx;
}

.date-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #5B7CF9;
  margin-right: 12rpx;
}

.date-full {
  font-size: 22rpx;
  color: #9CA3AF;
}
