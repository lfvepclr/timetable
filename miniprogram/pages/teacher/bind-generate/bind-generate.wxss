/* pages/teacher/bind-generate/bind-generate.wxss */
@import '/styles/variables.wxss';

.page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 180rpx;
}

.student-info {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: var(--color-card);
  margin-bottom: 24rpx;
}

.student-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.student-detail {
  display: flex;
  flex-direction: column;
}

.student-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.student-desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.section {
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
}

.binding-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.binding-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
}

.binding-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-success-bg);
  color: var(--color-success);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.binding-info {
  display: flex;
  flex-direction: column;
}

.binding-name {
  font-size: var(--font-base);
  color: var(--color-text-primary);
}

.binding-rel {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.code-section {
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.code-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-area {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 32rpx;
}

.qr-image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
}

.qr-placeholder {
  width: 400rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  margin-bottom: 32rpx;
}

.placeholder-text {
  font-size: var(--font-sm);
  color: var(--color-text-placeholder);
}

.code-display {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.code-text {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 8rpx;
}

.copy-btn {
  font-size: var(--font-sm);
  color: var(--color-primary);
  padding: 8rpx 24rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: var(--radius-pill);
}

.code-hint {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  text-align: center;
}

.actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  background: var(--color-card);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.btn-refresh, .btn-share {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  border: none;
}

.btn-refresh {
  background: var(--color-info-bg);
  color: var(--color-text-regular);
}

.btn-share {
  background: var(--color-primary);
  color: #fff;
}
