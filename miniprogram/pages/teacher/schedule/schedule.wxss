/* pages/teacher/schedule/schedule.wxss */
.page-container {
  padding: 16rpx 24rpx 120rpx;
}

/* 周导航 */
.week-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #5B7CF9;
  border-radius: 50%;
}

.nav-hover {
  background: #F0F4F8;
}

.week-label {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
}

/* 日期选择条 */
.date-bar {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.date-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 4rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.cell-hover {
  opacity: 0.7;
}

.date-cell.active {
  background: #5B7CF9;
  border-color: #5B7CF9;
}

.cell-weekday {
  font-size: 24rpx;
  color: #6B7280;
}

.date-cell.active .cell-weekday {
  color: rgba(255, 255, 255, 0.8);
}

.cell-date {
  font-size: 26rpx;
  color: #1F2937;
  font-weight: 500;
  margin-top: 4rpx;
}

.date-cell.active .cell-date {
  color: #FFFFFF;
}

.cell-count {
  font-size: 20rpx;
  color: #5B7CF9;
  margin-top: 4rpx;
  font-weight: 500;
}

.cell-count.active {
  color: rgba(255, 255, 255, 0.9);
}

/* 操作按钮 */
.action-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background: #5B7CF9;
  color: #FFFFFF;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.outline {
  background: transparent;
  color: #5B7CF9;
  border: 2rpx solid #5B7CF9;
}

.btn-hover {
  opacity: 0.85;
}

/* 日视图 */
.day-view {
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
}

.day-header {
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.day-date {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
}

.loading-text {
  text-align: center;
  color: #9CA3AF;
  padding: 40rpx;
  font-size: 26rpx;
}
