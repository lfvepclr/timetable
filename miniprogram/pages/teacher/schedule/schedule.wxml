<!-- pages/teacher/schedule/schedule.wxml -->
<wxs src="/wxs/helpers.wxs" module="h" />
<view class="page-container">
  <!-- 周导航 -->
  <view class="week-nav">
    <view class="nav-btn" bindtap="prevWeek" hover-class="nav-hover">
      <text>‹</text>
    </view>
    <view class="week-label" bindtap="goToday">
      <text>{{h.dateMD(currentWeek.start)}} ~ {{h.dateMD(currentWeek.end)}}</text>
    </view>
    <view class="nav-btn" bindtap="nextWeek" hover-class="nav-hover">
      <text>›</text>
    </view>
  </view>

  <!-- 日期选择条 -->
  <view class="date-bar">
    <block wx:for="{{weekDates}}" wx:key="*this">
      <view class="date-cell {{activeDayIndex === index ? 'active' : ''}}" data-index="{{index}}" bindtap="selectDate" hover-class="cell-hover">
        <text class="cell-weekday">{{h.weekdayInitial(index)}}</text>
        <text class="cell-date">{{h.dateMD(item)}}</text>
        <text wx:if="{{dayLessonCounts[index] > 0}}" class="cell-count {{activeDayIndex === index ? 'active' : ''}}">{{dayLessonCounts[index]}}节</text>
      </view>
    </block>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <view class="action-btn" bindtap="goToSchedule" hover-class="btn-hover">
      <text>+ 手动排课</text>
    </view>
    <view class="action-btn outline" bindtap="goToPattern" hover-class="btn-hover">
      <text>周期排课</text>
    </view>
  </view>

  <!-- 日视图（时间折叠） -->
  <view class="day-view">
    <view class="day-header">
      <text class="day-date">{{selectedDate}}</text>
    </view>
    <block wx:if="{{!loading}}">
      <time-fold wx:if="{{daySegments.length > 0}}" segments="{{daySegments}}" bind:lessontap="onLessonTap" />
      <t-empty wx:else icon="info-circle-filled" description="当日无课" />
    </block>
    <view wx:else class="loading-text">加载中...</view>
  </view>

  <custom-tab-bar id="tabBar" />
</view>
