<!-- pages/teacher/lesson-detail/lesson-detail.wxml -->
<wxs src="/wxs/helpers.wxs" module="h" />
<view class="page-container" wx:if="{{!loading && lesson}}">
  <!-- 课程信息卡片 -->
  <view class="info-card">
    <view class="course-bar" style="background: {{lesson.color || '#5B7CF9'}};"></view>
    <view class="info-body">
      <view class="info-header">
        <text class="course-name">{{lesson.course_name}}</text>
        <t-tag theme="{{h.statusTheme(lesson.lesson_status, 'lesson')}}" variant="light" size="small">{{h.statusText(lesson.lesson_status, 'lesson')}}</t-tag>
      </view>
      <view class="info-row">
        <text class="info-label">时间</text>
        <text class="info-value">{{lesson.date}} {{lesson.weekday}} {{lesson.start_time}}-{{lesson.end_time}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">时长</text>
        <text class="info-value">{{lesson.durationText}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">类型</text>
        <text class="info-value">{{lesson.course_type}}</text>
      </view>
    </view>
  </view>

  <!-- 学生列表 -->
  <view class="section">
    <view class="section-title">参课学生（{{lesson.students.length}}）</view>
    <block wx:for="{{lesson.students}}" wx:key="student_id">
      <t-cell title="{{item.student_name}}" hover>
        <view slot="left-icon" class="cell-avatar" style="background: {{h.avatarColor(index)}};">
          <text class="cell-avatar-text">{{h.firstChar(item.student_name)}}</text>
        </view>
        <view slot="note">
          <t-tag theme="{{h.statusTheme(item.status, 'lesson')}}" variant="light" size="small">{{h.statusText(item.status, 'lesson')}}</t-tag>
        </view>
        <view slot="right-icon" class="student-actions">
          <t-button wx:if="{{item.status === 'scheduled'}}" theme="warning" variant="text" size="small" data-sid="{{item.student_id}}" bind:tap="showLeaveDialog">请假</t-button>
          <t-button wx:if="{{item.status === 'on_leave'}}" theme="primary" variant="text" size="small" data-sid="{{item.student_id}}" bind:tap="goToReschedule">补课</t-button>
          <t-button wx:if="{{item.status === 'attended'}}" theme="primary" variant="text" size="small" data-sid="{{item.student_id}}" bind:tap="goToFeedback">反馈</t-button>
        </view>
      </t-cell>
    </block>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-actions" wx:if="{{lesson.lesson_status === 'scheduled'}}">
    <t-button theme="primary" size="large" block bind:tap="showCompleteDialog">标记下课</t-button>
  </view>
</view>

<!-- 完成课程弹窗 -->
<t-popup visible="{{showComplete}}" bind:visible-change="onCompletePopupChange" placement="center">
  <view class="complete-dialog">
    <view class="dialog-title">确认下课</view>
    <view class="dialog-desc">勾选出勤学生，将消耗对应课时</view>
    <t-checkbox-group value="{{attendedIds}}" bind:change="onAttendChange">
      <t-checkbox wx:for="{{lesson.students}}" wx:for-item="student" wx:key="student_id" label="{{student.student_name}}" value="{{student.student_id}}" />
    </t-checkbox-group>
    <view class="dialog-actions">
      <t-button theme="default" bind:tap="hideCompleteDialog">取消</t-button>
      <t-button theme="primary" bind:tap="confirmComplete">确认下课</t-button>
    </view>
  </view>
</t-popup>

<!-- 请假弹窗 -->
<t-popup visible="{{showLeaveDialog}}" bind:visible-change="onLeavePopupChange" placement="center">
  <view class="leave-dialog">
    <view class="dialog-title">学生请假</view>
    <t-textarea label="请假原因（选填）" placeholder="如：生病、临时有事" value="{{leaveReason}}" bind:change="onLeaveReasonInput" />
    <view class="dialog-actions">
      <t-button theme="default" bind:tap="hideLeaveDialog">取消</t-button>
      <t-button theme="primary" bind:tap="confirmLeave">确认请假</t-button>
    </view>
  </view>
</t-popup>
