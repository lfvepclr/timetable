<!-- pages/parent/schedule/schedule.wxml -->
<wxs src="/wxs/helpers.wxs" module="h" />
<view class="page">
  <!-- 周导航 -->
  <view class="week-nav">
    <view class="nav-btn" bindtap="prevWeek">‹</view>
    <view class="week-dates">
      <view
        class="date-item {{selectedDate === item ? 'selected' : ''}} {{item === today ? 'today' : ''}}"
        wx:for="{{weekDates}}" wx:key="*this"
        data-date="{{item}}" bindtap="onSelectDate"
      >
        <text class="date-weekday">{{h.weekdayInitial(index)}}</text>
        <text class="date-day">{{h.dateDay(item)}}</text>
      </view>
    </view>
    <view class="nav-btn" bindtap="nextWeek">›</view>
  </view>

  <!-- 课程列表 -->
  <view class="lesson-area">
    <view wx:if="{{loading}}" class="loading">加载中...</view>

    <block wx:if="{{!loading}}">
      <time-fold wx:if="{{segments.length > 0}}" segments="{{segments}}" bind:lessontap="onLessonTap" />
      <t-empty wx:else icon="info-circle-filled" description="今天没有课程" />
    </block>
  </view>

  <custom-tab-bar id="tabBar" />
</view>
