/* pages/parent/feedback-detail/feedback-detail.wxss */
@import '/styles/variables.wxss';

.page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 140rpx;
}

.header {
  position: relative;
  height: 200rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
}

.header-content {
  position: relative;
  z-index: 1;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
}

.header-date {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.header-course {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: #fff;
}

.content {
  padding: 24rpx;
}

.section {
  display: flex;
  padding: 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
}

.section-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-book { background: var(--color-primary-bg); color: var(--color-primary); }
.icon-star { background: var(--color-success-bg); color: var(--color-success); }
.icon-edit { background: var(--color-warning-bg); color: var(--color-warning); }
.icon-heart { background: #FDEAEA; color: var(--color-danger); }

.section-body {
  flex: 1;
}

.section-title {
  display: block;
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.section-text {
  font-size: var(--font-sm);
  color: var(--color-text-regular);
  line-height: 1.8;
}

.photos {
  padding: 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.photos-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
  display: block;
}

.photos-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
}

.share-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  background: var(--color-card);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.btn-share {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-md);
  font-weight: 600;
  border-radius: var(--radius-md);
  border: none;
}

.loading {
  text-align: center;
  padding: 80rpx;
  color: var(--color-text-secondary);
}
